# Site Configuration
NEXT_PUBLIC_SITE_URL=https://renekrajnc.com

# Google reCAPTCHA
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
# Optional: v3 score threshold (0.0 to 1.0). Defaults to 0.5 if omitted/invalid.
RECAPTCHA_MIN_SCORE=0.5

# Resend (Contact email delivery)
RESEND_API_KEY=your_resend_api_key
# Optional: sender identity (must be allowed in your Resend account)
RESEND_FROM_EMAIL=Rene Krajnc <info@renekrajnc.com>
# Optional: sender display name used when RESEND_FROM_EMAIL is only an address
RESEND_FROM_NAME=Rene Krajnc Info
# Optional: public base URL for images used in emails (must be publicly reachable)
EMAIL_ASSET_BASE_URL=https://renekrajnc.com

# For production: Use your actual production domain
# For local development: http://localhost:3000
